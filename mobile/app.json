{
  "expo": {
    "name": "PicoPico",
    "slug": "picopico",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alexscshin73.picopico"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ceaa895e-f7c5-4635-a930-f56de47b2d93"
      }
    },
    "owner": "alexscshin73",
    "plugins": [
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "스페인어 발음을 인식하기 위해 마이크 권한이 필요합니다.",
          "speechRecognitionPermission": "스페인어 음성을 텍스트로 변환하기 위해 음성 인식 권한이 필요합니다."
        }
      ]
    ]
  }
}
